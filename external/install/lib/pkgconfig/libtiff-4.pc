prefix=/Users/chris/Documents/GitHub/QCView-Player/external/install
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: libtiff
Description:  Tag Image File Format (TIFF) library.
Version: 4.7.0
Libs: -L${libdir} -ltiff
Libs.private:  -lm
Cflags: -I${includedir}
Requires.private:  zlib libdeflate libjpeg libzstd libwebp
